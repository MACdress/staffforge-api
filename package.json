{
  "name": "staffforge-api",
  "version": "1.0.0",
  "description": "StaffForge API - Cloudflare Workers",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create staffforge-db",
    "d1:migrate": "wrangler d1 execute staffforge-db --file=src/db/schema.sql",
    "d1:migrate:local": "wrangler d1 execute staffforge-db --local --file=src/db/schema.sql"
  },
  "dependencies": {
    "itty-router": "^4.2.0",
    "jose": "^5.2.0"
  },
  "devDependencies": {
    "wrangler": "^4.78.0"
  }
}
